            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"descricao\": \"Alimentação\",\n  \"finalidade\": 0\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/categorias",
              "host": ["{{baseUrl}}"],
              "path": ["api", "categorias"]
            },
            "description": "Cria uma nova categoria no sistema\n\nValores para 'finalidade':\n- 0: Despesa\n- 1: Receita\n- 2: Ambos"
          }
        }
      ]
    },
