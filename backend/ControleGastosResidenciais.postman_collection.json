{
  "info": {
    "name": "Controle de Gastos Residenciais API",
    "description": "API para gerenciamento de despesas e receitas pessoais",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Pessoas",
      "item": [
        {
          "name": "Obter Todas as Pessoas",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/pessoas",
              "host": ["{{baseUrl}}"],
              "path": ["api", "pessoas"]
            },
            "description": "Retorna uma lista de todas as pessoas cadastradas"
          }
        },
        {
          "name": "Obter Pessoa por ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/pessoas/:id",
              "host": ["{{baseUrl}}"],
              "path": ["api", "pessoas", ":id"],
              "variable": [
                {
                  "key": "id",
                  "value": "00000000-0000-0000-0000-000000000000",
                  "description": "ID da pessoa (GUID)"
                }
              ]
            },
            "description": "Retorna os dados de uma pessoa específica pelo ID"
          }
        },
        {
          "name": "Criar Nova Pessoa",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"João Silva\",\n  \"idade\": 25\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/pessoas",
              "host": ["{{baseUrl}}"],
              "path": ["api", "pessoas"]
            },
            "description": "Cria uma nova pessoa no sistema"
          }
        },
        {
          "name": "Atualizar Pessoa",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"João Silva Santos\",\n  \"idade\": 26\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/pessoas/:id",
              "host": ["{{baseUrl}}"],
              "path": ["api", "pessoas", ":id"],
              "variable": [
                {
                  "key": "id",
                  "value": "00000000-0000-0000-0000-000000000000",
                  "description": "ID da pessoa (GUID)"
                }
              ]
            },
            "description": "Atualiza os dados de uma pessoa existente"
          }
        },
        {
          "name": "Excluir Pessoa",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/pessoas/:id",
              "host": ["{{baseUrl}}"],
              "path": ["api", "pessoas", ":id"],
              "variable": [
                {
                  "key": "id",
                  "value": "00000000-0000-0000-0000-000000000000",
                  "description": "ID da pessoa (GUID)"
                }
              ]
            },
            "description": "Remove uma pessoa do sistema (com exclusão em cascata)"
          }
        }
      ]
    },
    {
      "name": "Categorias",
